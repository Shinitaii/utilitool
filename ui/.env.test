# E2E test environment — UI talks to local Firebase emulators + local API (dev:emulator).
# See decisions/20260611_emulator-for-e2e-testing.md. Used only by `npm run test:e2e`.
VITE_FIREBASE_API_KEY=fake-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=utilitool-test
VITE_FIREBASE_STORAGE_BUCKET=utilitool-test.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:test
VITE_API_BASE_URL=http://127.0.0.1:5002
VITE_USE_FIREBASE_EMULATOR=true
